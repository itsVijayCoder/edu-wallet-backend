# ─── Server ───────────────────────────────────────────────────
APP_ENV=development
APP_MODE=api
APP_PORT=8080
APP_NAME=eduwallet
# Production requires an HTTPS external URL and explicit HTTPS CORS origins.
# APP_EXTERNAL_URL=http://localhost:8080
# CORS_ALLOWED_ORIGINS=http://localhost:3000
WORKER_POLL_INTERVAL=5s

# ─── Auth ─────────────────────────────────────────────────────
# Public registration is allowed by default outside production.
# In production, set this to true only when self-signup is intended.
AUTH_PUBLIC_REGISTRATION_ENABLED=false

# ─── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=eduwallet
DB_PASSWORD=eduwallet_secret
DB_NAME=eduwallet_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ──────────────────────────────────────────────────────
# REQUIRED: Generate with `openssl rand -base64 48`
# WARNING: Do not use the defaults in production!
JWT_ACCESS_SECRET=bpE7BVga1ld2q7YJybICbop8fHXh05pUTnZFiaPonpAdPMIOmn9+B2hE3otZBi1Y
JWT_REFRESH_SECRET=bpE7BVga1ld2q7YJybICbop8fHXh05pUTnZFiaPonpAdPMIOmn9+B2hE3otZBi1Y
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ─── Email (Resend) ──────────────────────────────────────────
# Optional: leave RESEND_API_KEY empty to disable email sending
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=eduwallet

# ─── Payments ─────────────────────────────────────────────────
# Use `fake` locally/e2e. Use `razorpay` with Razorpay test/live keys.
# Production requires PAYMENT_PROVIDER=razorpay and all Razorpay secrets.
PAYMENT_PROVIDER=fake
PAYMENT_FAKE_SIGNING_SECRET=test_payment_secret
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_BASE_URL=https://api.razorpay.com/v1
